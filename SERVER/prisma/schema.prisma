// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Changed models or fields → npx prisma migrate dev
// Only tooling/config change → npx prisma generate
// Fresh machine, DB already in sync → npx prisma generate

// always use the plural naming convention for model names, e.g. "Users" instead of "User"  

model Users {
  id           Int     @id @default(autoincrement())
  username     String  @unique
  email        String  @unique
  password     String
  // ? --> it show the optional field, if the field is not required, it can be null
  fullName     String?
  bio          String? @db.VarChar(200)
  profileImage String?
  website      String?
  location     String?
  isPrivate    Boolean @default(false)
  isVerified   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts Posts[]
  // followers       Follow[] @relation("UserFollowers")
  // following       Follow[] @relation("UserFollowing")
  // comments        Comment[]
  // likes           Like[]
  // savedPosts      SavedPost[]
  // notifications   Notification[]
}

model Posts {
  id Int @id @default(autoincrement())
  caption String?
  createdAt DateTime @default(now())
  userId Int
  user Users @relation(fields: [userId], references: [id])
}

model Balajis {
  id        Int    @id @default(autoincrement())
  username  String @unique
  password  String
  firstName String
  lastName  String
}
